#
# Wazi Deploy Test environment configuration
# This file contains common settings for Wazi Deploy Ansible and Python based test scripts
#

# User Configuration
TMPHLQ="IBMUSER"

# Deployment Method
DEPLOYMENT_METHOD=${SCRIPT_DIR}/../../deployment-configuration/deployment-method.yml

# Deployment Configuration
# used to dynamically load additional configuration
DEPLOYMENT_CONFIG_HOME=${SCRIPT_DIR}/../../

# Target Library Configuration
TARGET_HLQ="IBMUSER.WD.TEST"

# Application Configuration
APPLICATION="base"

# Package URL
# Note: Replace with your own test package
PACKAGE_URL="http://10.3.20.231:8081/artifactory/base-dbehm-repo-local/release/rel-1.0.0/base-rel-1.0.0-2025-06-27_08-52-10.tar"

# Ansible Configuration
ANSIBLE_INVENTORY="inventories"
ZOS_ENVIRONMENT="int_a_zos_host"

# Wazi Deploy configuration file for Ansible path to access artifact repo
WAZI_DEPLOY_CONFIG_FILE_ANSIBLE=/var/git/artifactoryConfig.yml

# Ansible setup
export PATH=/usr/local/bin/:$PATH

# Python stream configuration
PYTHON_VENV=/var/python-envs/wazi-deploy-v3.0.7.1
ZOAU_HOME_DIR=/var/zoau-1.3.6.0

# Wazi Deploy configuration file for Python path to access artifact repo
WAZI_DEPLOY_CONFIG_FILE_PYTHON=/var/WaziDeploy/config/WaziDeploy-ConfigFile.yml
